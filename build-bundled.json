{
  "appId": "com.johanes.ytdl",
  "productName": "JoDL",
  "directories": {
    "output": "dist/bundled"
  },
  "artifactName": "${productName}-Setup-${version}.${ext}",
  "files": [
    "src/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "src/assets/icon.png",
    "extraFiles": [
      { "from": "bin",    "to": "bin" },
      { "from": "ffmpeg", "to": "ffmpeg" },
      { "from": "node",   "to": "node" }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "shortcutName": "JoDL",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}